# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
# Local dev: run `mongod` and point at a local database
MONGODB_URI=mongodb://127.0.0.1:27017/vsmart_placement
# Production: replace with your MongoDB Atlas connection string
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vsmart_placement

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES=7d

# Cloudinary (sign up at https://cloudinary.com and paste your dashboard credentials)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
